# Mẫu biến môi trường. Copy file này thành .env.local rồi điền giá trị thật.
# Lấy connection string từ https://neon.tech → project của bạn → "Connection string".
DATABASE_URL=

# Đăng nhập trang /admin bằng mật khẩu
# AUTH_SECRET: chuỗi bí mật để ký cookie — sinh bằng: openssl rand -base64 32
AUTH_SECRET=
# Mật khẩu để đăng nhập trang quản trị
ADMIN_PASSWORD=
