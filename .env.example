# Mẫu biến môi trường. Copy file này thành .env.local rồi điền giá trị thật.
# Lấy connection string từ https://neon.tech → project của bạn → "Connection string".
DATABASE_URL=

# Đăng nhập admin (NextAuth / Google OAuth)
# AUTH_SECRET: sinh bằng lệnh: openssl rand -base64 32
AUTH_SECRET=
# Email Google được phép vào trang /admin
ADMIN_EMAIL=
# Lấy từ Google Cloud Console → Credentials → OAuth client ID
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
